{
  "private": true,
  "name": "island-rain",
  "version": "0.0.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "npm run type-check && npm run lint && devvit upload",
    "dev": "devvit playtest",
    "launch": "npm run deploy && devvit publish",
    "lint": "eslint src",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "type-check": "tsc --build",
    "compress-glb": "gltf-transform optimize src/client/game/assets/low_poly_island_environment.glb src/client/game/assets/low_poly_island_environment.glb --texture-compress webp --compress draco"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.13.6",
    "@devvit/web": "0.13.6",
    "@hono/node-server": "2.0.5",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "devvit": "0.13.6",
    "hono": "4.12.27",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "^0.185.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "^22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0"
  }
}
